#pragma once

// Add as many networks as you need. The device connects to whichever
// is in range, preferring the strongest signal.
#define WIFI_NETWORKS(multi) \
    multi.addAP("YourSSID", "YourPassword"); \
    multi.addAP("SecondSSID", "SecondPassword");

#define MQTT_BROKER   "mqtt.example.com"
#define MQTT_PORT     1883
#define MQTT_USER     "your_mqtt_user"
#define MQTT_PASS     "your_mqtt_password"
